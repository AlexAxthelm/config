{
  "permissions": {
    "deny": ["Bash(git commit:*)", "Bash(git push:*)"]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.config/claude/hooks/block-git-write.sh"
          }
        ]
      }
    ]
  }
}
